<Window x:Class="GoldPriceWatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GoldPriceWatch"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:convert="clr-namespace:GoldPriceWatch.Convert"
        mc:Ignorable="d"
        Title="黄金价格监控" 
        Height="60" Width="220"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Topmost="True"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewMouseMove="Window_PreviewMouseMove"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp">

    <Window.Resources>
        <convert:BoolToStringConverter x:Key="PriceTrendSymbolConverter" />

        <Style x:Key="PriceTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Rise}" Value="True">
                    <Setter Property="Foreground" Value="#FF4A4A"/>
                    <!-- 更柔和的红色 -->
                </DataTrigger>
                <DataTrigger Binding="{Binding Rise}" Value="False">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                    <!-- 更柔和的绿色 -->
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- 使用阴影效果增强视觉层次 -->
    <Border CornerRadius="10" 
            Padding="10,5"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" 
                              ShadowDepth="2" 
                              Opacity="0.6" 
                              Color="Black"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    TextElement.FontFamily="Segoe UI">

            <!-- 当前价格 -->
            <TextBlock Text="{Binding Text, StringFormat='{}{0:C}'}" 
                       Style="{StaticResource PriceTextStyle}"
                       MinWidth="80"
                       TextAlignment="Right"/>

            <!-- 价格变动信息 -->
            <TextBlock Style="{StaticResource PriceTextStyle}" 
                       Margin="8,0,0,0">
                <Run Text="{Binding Rise, Converter={StaticResource PriceTrendSymbolConverter}, ConverterParameter='↑|↓'}"/>
                <Run Text="{Binding PriceRangePercentage}"/>
            </TextBlock>

            <!-- 可选：添加一个刷新时间 -->
            <TextBlock Text="{Binding LastUpdated, StringFormat='(更新: {0:HH:mm})'}" 
                       Foreground="#AAAAAA"
                       FontSize="10"
                       Margin="8,0,0,0"
                       VerticalAlignment="Bottom"/>
        </StackPanel>
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="设置对比价格"/>
                <MenuItem Header="退出" Click="MenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</Window>