<!-- MainWindow.xaml -->
<Window x:Class="GoldPriceWatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GoldPriceWatch"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:convert="clr-namespace:GoldPriceWatch.Convert"
        mc:Ignorable="d"
        Title="黄金价格监控" 
        Height="80" Width="300"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewMouseMove="Window_PreviewMouseMove"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp">

    <Window.Resources>
        <!-- Converter for trend symbol (assuming BoolToStringConverter is defined in Convert namespace) -->
        <convert:BoolToStringConverter x:Key="PriceTrendSymbolConverter" />

        <!-- Flashing Animation -->
        

        <!-- Base Price Text Style -->
        <Style x:Key="PriceTextStyle" TargetType="TextBlock">
            <Style.Resources>
                <Storyboard x:Key="FlashingAnimation" RepeatBehavior="3x" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                     From="1.0" To="0.7" Duration="0:0:0.3"/>
                </Storyboard>
                <Storyboard x:Key="FetchPulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
					 From="1.0" To="0.65" Duration="0:0:0.45"/>
                </Storyboard>
            </Style.Resources>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="1.0"/>
            <Style.Triggers>
                <!-- Rise: Green -->
                <DataTrigger Binding="{Binding IsRise}" Value="True">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </DataTrigger>
                <!-- Drop: Red -->
                <DataTrigger Binding="{Binding IsRise}" Value="False">
                    <Setter Property="Foreground" Value="#F44336"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                    <!--<Setter Property="Foreground" Value="#FB8C00"/>-->
                    <Setter Property="Foreground" Value="Gray"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFetching}" Value="True">
                    <Setter Property="Foreground" Value="#1E88E5"/>
                    <Setter Property="Opacity" Value="0.7"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="FetchPulseStoryboard" Storyboard="{StaticResource FetchPulseAnimation}"/>
                    </DataTrigger.EnterActions>
                    <!-- <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="FetchPulseStoryboard"/>
                    </DataTrigger.ExitActions> -->
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Info Text Style -->
        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FetchStateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource InfoTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                    <!--<Setter Property="Foreground" Value="#FB8C00"/>-->
                    <Setter Property="Foreground" Value="#FB8C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFetching}" Value="True">
                    <Setter Property="Foreground" Value="#1E88E5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Border Style with Glow for Alerts -->
        <Style x:Key="AlertBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFlashing}" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.8" Color="#FFD700"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Alert-Specific TextBlock Styles for Flashing -->
        <Style x:Key="RiseAlertTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PriceTextStyle}">
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRiseAlert}" Value="True"/>
                        <Condition Binding="{Binding IsFlashing}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="#8BC34A"/>
                    <Setter Property="Opacity" Value="0.75"/>
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="RiseAlertFlashStoryboard" Storyboard="{StaticResource FlashingAnimation}"/>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="RiseAlertFlashStoryboard"/>
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DropAlertTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PriceTextStyle}">
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsDropAlert}" Value="True"/>
                        <Condition Binding="{Binding IsFlashing}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="#EF5350"/>
                    <Setter Property="Opacity" Value="0.75"/>
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="DropAlertFlashStoryboard" Storyboard="{StaticResource FlashingAnimation}"/>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="DropAlertFlashStoryboard"/>
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Enhanced layout for more info while keeping compact -->
    <Border Style="{StaticResource AlertBorderStyle}"
            BorderBrush="#E0E0E0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Top Row: Current Price & Trend -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                <TextBlock Text="{Binding CurrentPriceText}" 
                           Style="{StaticResource PriceTextStyle}"
                           TextAlignment="Right"/>
                <TextBlock Style="{StaticResource PriceTextStyle}" Margin="4,0">
                    <Run Text="{Binding IsRise, Converter={StaticResource PriceTrendSymbolConverter}, ConverterParameter='↑|↓'}"/>
                    <Run Text="{Binding PriceRangePercentage}"/>
                </TextBlock>
                <TextBlock Text="{Binding FetchStatusText}" Style="{StaticResource FetchStateTextStyle}" Margin="8,0,0,0"/>
                <TextBlock Text="{Binding LastUpdated, StringFormat='({0:HH:mm:ss})'}" 
           Style="{StaticResource InfoTextStyle}"/>
            </StackPanel>

            <!-- Middle Row: Profit/Loss -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                <TextBlock Text="{Binding PurchasePriceText}" Style="{StaticResource InfoTextStyle}" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ProfitLossAmountText}" 
                           Style="{StaticResource RiseAlertTextStyle}"
                           MinWidth="50"
                           TextAlignment="Right"/>
                <TextBlock Text="{Binding ProfitLossPercentageText}" 
                           Style="{StaticResource DropAlertTextStyle}"
                           Margin="4,0,0,0"/>
            </StackPanel>

             <!--Bottom Row: Totals & Update Time--> 
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="{Binding CurrentTotalValue}" Style="{StaticResource InfoTextStyle}" Margin="0,0,4,0"/>
                <TextBlock Text="/ " />
                <TextBlock Text="{Binding PurchaseTotalValue}" Style="{StaticResource InfoTextStyle}" Margin="0,0,8,0"/>
            </StackPanel>
        </Grid>

        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="配置" Click="MenuItem_Click_1"/>
                <MenuItem Header="退出" Click="MenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</Window>