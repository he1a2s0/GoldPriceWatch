<Window x:Class="GoldPriceWatch.GoldInvestmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2006"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:GoldPriceWatch"
        xmlns:convert="clr-namespace:GoldPriceWatch.Convert"
        mc:Ignorable="d"
        Title="黄金投资配置" Height="700" Width="550"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="500"
        ResizeMode="CanResize">
    <Window.Resources>
        <!-- 全局样式：标签 -->
        <Style x:Key="FormLabelStyle" TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTipService.ShowDuration" Value="5000"/>
        </Style>
        <!-- 全局样式：文本框 -->
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 全局样式：组合框 -->
        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 全局样式：复选框 -->
        <Style x:Key="FormCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 验证错误样式 -->
        <Style x:Key="ValidationErrorStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="Red"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={x:Static RelativeSource.Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" 
                  VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
            <StackPanel Margin="24" Orientation="Vertical">
                <!-- 标题 -->
                <TextBlock Text="黄金投资配置管理" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,24"
                       Foreground="#2C3E50"/>

                <GroupBox
                      BorderBrush="#BDC3C7" 
                      Background="#F8F9FA"
                      Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="基本信息" 
                               FontWeight="SemiBold" 
                               Foreground="#34495E"/>
                    </GroupBox.Header>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 展示通知 -->
                        <Label Grid.Row="4" Grid.Column="0" 
                           Content="是否通知报警:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="开启后价格高于/低于您设定的数值将会报警。"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" 
                                  IsChecked="{Binding ShowNotice, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- 买入价格 -->
                        <Label Grid.Row="0" Grid.Column="0" 
                           Content="买入价格 (每单位):" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="您买入黄金的单价，例如每克人民币价格"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                             Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                             Style="{StaticResource FormTextBoxStyle}"/>

                        <!-- 总克数 -->
                        <Label Grid.Row="1" Grid.Column="0" 
                           Content="总克数:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="您总共购买的黄金克数"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding TotalGrams, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                             Style="{StaticResource FormTextBoxStyle}"/>

                        <!-- 单位 -->
                        <Label Grid.Row="2" Grid.Column="0" 
                           Content="单位:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="价格单位：克或盎司"/>
                        <hc:ComboBox Grid.Row="2" Grid.Column="1" 
                              SelectedValue="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding GoldUnitList}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Value">
                        </hc:ComboBox>

                        <!-- 货币 -->
                        <Label Grid.Row="3" Grid.Column="0" 
                           Content="货币:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="价格货币类型，如 CNY 或 USD"/>
                        <TextBox Grid.Row="3" Grid.Column="1" 
                             Text="{Binding Currency, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource FormTextBoxStyle}"/>
                    </Grid>
                </GroupBox>

                <GroupBox 
                      BorderBrush="#BDC3C7" 
                      Background="#F8F9FA"
                      Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="卖出/止损设置" 
                               FontWeight="SemiBold" 
                               Foreground="#34495E"/>
                    </GroupBox.Header>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" 
                           Content="目标卖出价格:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="达到此价格时提醒卖出，实现盈利目标"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                             Text="{Binding TargetSellPrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                             Style="{StaticResource FormTextBoxStyle}"/>

                        <Label Grid.Row="1" Grid.Column="0" 
                           Content="止损价格:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="价格跌至此值时警报，防止进一步亏损"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding StopLossPrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                             Style="{StaticResource FormTextBoxStyle}"/>
                    </Grid>
                </GroupBox>

                <GroupBox 
                      BorderBrush="#BDC3C7" 
                      Background="#F8F9FA"
                      Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="降价报警" 
                               FontWeight="SemiBold" 
                               Foreground="#34495E"/>
                    </GroupBox.Header>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" 
                           Content="阈值类型:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="选择百分比（%）或绝对金额作为报警依据"/>
                        <hc:ComboBox Grid.Row="0" Grid.Column="1" 
                              SelectedValue="{Binding DropAlertType, UpdateSourceTrigger=PropertyChanged}"
                                     ItemsSource="{Binding AlertThresholdTypeList}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Value">
                        </hc:ComboBox>

                        <Label Grid.Row="1" Grid.Column="0" 
                           Content="阈值:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="例如 5 表示 5% 或 5 元/克的下跌"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding DropAlertThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                             Style="{StaticResource FormTextBoxStyle}"/>
                    </Grid>
                </GroupBox>

                <GroupBox 
                      BorderBrush="#BDC3C7" 
                      Background="#F8F9FA"
                      Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="涨价提醒" 
                               FontWeight="SemiBold" 
                               Foreground="#34495E"/>
                    </GroupBox.Header>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" 
                           Content="阈值类型:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="选择百分比（%）或绝对金额作为提醒依据"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" 
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Value"
                              SelectedValue="{Binding DropAlertType, UpdateSourceTrigger=PropertyChanged}"
                                     ItemsSource="{Binding AlertThresholdTypeList}">
                        </ComboBox>

                        <Label Grid.Row="1" Grid.Column="0" 
                           Content="阈值:" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="例如 5 表示 5% 或 5 元/克的上涨"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding RiseAlertThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                             Style="{StaticResource FormTextBoxStyle}"/>
                    </Grid>
                </GroupBox>

                <GroupBox  
                      BorderBrush="#BDC3C7" 
                      Background="#F8F9FA"
                      Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="其他设置" 
                               FontWeight="SemiBold" 
                               Foreground="#34495E"/>
                    </GroupBox.Header>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" 
                           Content="波动率阈值 (%):" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="当日价格波动超过此百分比时警报"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                             Text="{Binding VolatilityThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                             Style="{StaticResource FormTextBoxStyle}"/>

                        <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="启用每日结算价提醒" 
                              IsChecked="{Binding EnableSettlementAlert, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource FormCheckBoxStyle}"
                              ToolTip="每日结束时提醒结算价变化"/>

                        <Label Grid.Row="2" Grid.Column="0" 
                           Content="通知渠道 (逗号分隔):" 
                           Style="{StaticResource FormLabelStyle}"
                           ToolTip="如 Console,Email，支持多个渠道用逗号分隔"/>
                        <TextBox Grid.Row="2" Grid.Column="1" 
                             Text="{Binding NotificationChannelsString, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource FormTextBoxStyle}"
                             Height="60"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- 操作按钮栏 -->
        <StackPanel Grid.Row="1" 
                Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                Margin="0,16,24,24">
            <Button Content="保存配置" 
                Command="{Binding SaveCommand}" 
                Style="{StaticResource ActionButtonStyle}"
                Background="#27AE60"/>
            <Button Content="加载配置" 
                Command="{Binding LoadCommand}" 
                Style="{StaticResource ActionButtonStyle}"
                Background="#3498DB"/>
            <Button Content="取消" 
                Command="{Binding CancelCommand}" 
                Style="{StaticResource ActionButtonStyle}"
                Background="#95A5A6"/>
        </StackPanel>
    </Grid>
</Window>

